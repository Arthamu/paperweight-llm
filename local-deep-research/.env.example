# Get your API key at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Your local llama.cpp server endpoint
LLAMA_ENDPOINT=http://localhost:8080

# Optional: specify a model name (e.g., "llama-3.1-8b")
LLAMA_MODEL=

